<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Test | SonarIA</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f8fafc; }
    .card-modern { @apply bg-white border border-slate-200 rounded-[28px] shadow-sm transition-all duration-300; }
    .animate-in { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body class="p-6 md:p-12 text-slate-800">

  <header class="max-w-6xl mx-auto text-center mb-12">
    <h1 class="text-5xl md:text-7xl font-black tracking-tighter mb-4">Sonar<span class="text-blue-600">IA</span></h1>
    <h2 class="text-xl font-bold text-slate-400 italic">"Evaluación pedagógica visual para el aula moderna."</h2>
  </header>

  <main class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8">
    <!-- ENTRADA -->
    <div class="lg:col-span-4 space-y-6">
      <div class="card-modern p-8 bg-white/80 backdrop-blur-md">
        <h3 class="font-black mb-6 uppercase text-[10px] tracking-[0.2em] text-blue-600">Analizador de Staging</h3>
        <input id="titulo" type="text" placeholder="Canción" class="w-full p-4 bg-slate-50 rounded-2xl mb-4 border border-slate-200 font-bold outline-none focus:ring-4 focus:ring-blue-100 transition-all">
        <input id="artista" type="text" placeholder="Artista" class="w-full p-4 bg-slate-50 rounded-2xl mb-6 border border-slate-200 font-bold outline-none focus:ring-4 focus:ring-blue-100 transition-all">
        <button id="analyzeBtn" class="w-full py-4 bg-slate-900 text-white rounded-2xl font-black hover:bg-blue-600 transition-all shadow-xl active:scale-95">Evaluar Canción</button>
      </div>
    </div>

    <!-- RESULTADOS (EL SEMÁFORO) -->
    <div class="lg:col-span-8">
      <div id="analysisPlaceholder" class="h-full flex flex-col items-center justify-center text-center p-12 border-2 border-dashed border-slate-200 rounded-[40px] bg-white/40">
        <p class="text-slate-400 font-bold">Ingresa una canción para activar el semáforo visual.</p>
      </div>

      <div id="resultsWrapper" class="hidden space-y-6 animate-in">
        <div id="statusHero" class="card-modern border-t-[14px] p-10 transition-all duration-1000">
          <div class="flex justify-between items-start mb-8">
            <div id="suitabilityIcon" class="p-6 rounded-3xl bg-slate-100 text-slate-300 transition-all duration-700">
              <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div class="text-right">
              <div class="text-5xl font-black tracking-tighter" id="riskValue">0%</div>
              <div class="text-[10px] font-black uppercase text-slate-400 tracking-widest">Riesgo Detectado</div>
            </div>
          </div>
          <h2 id="summaryTitle" class="text-4xl font-black tracking-tight text-slate-900 mb-2">Veredicto</h2>
          <p id="summaryCopy" class="text-xl text-slate-500 font-medium italic leading-relaxed">—</p>
          
          <div class="grid grid-cols-3 gap-4 border-t pt-8 mt-4 text-center">
            <div><span class="block text-[10px] font-black text-slate-400 uppercase mb-1">Edad</span><span id="edadSugerida" class="text-xl font-black">—</span></div>
            <div><span class="block text-[10px] font-black text-slate-400 uppercase mb-1">Cursos</span><span id="cursosSugeridos" class="text-sm font-black">—</span></div>
            <div><span class="block text-[10px] font-black text-slate-400 uppercase mb-1">Ruta</span><span id="lecturaSugerida" class="text-[10px] font-black uppercase">—</span></div>
          </div>
        </div>

        <div class="card-modern p-8 bg-blue-50/50 border-blue-100">
          <h4 class="text-[10px] font-black text-blue-600 uppercase mb-3 tracking-widest">Estrategia Docente Recomendada</h4>
          <p id="explicacionPedagogica" class="text-slate-700 font-bold leading-relaxed italic text-lg">—</p>
        </div>
      </div>
    </div>
  </main>

  <script>
    // CTO: Apuntando a la API de TEST
    const API_BASE = "https://sonaria-api-test.onrender.com";
    const $ = id => document.getElementById(id);

    async function analizar() {
      const btn = $("analyzeBtn");
      btn.disabled = true; btn.innerText = "Consultando motor 1.5.3...";
      try {
        const res = await fetch(`${API_BASE}/analizar`, {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${localStorage.getItem("mejoraria_token")}` 
          },
          body: JSON.stringify({ titulo: $("titulo").value, artista: $("artista").value })
        });
        const data = await res.json();
        renderResult(data);
      } catch (e) { alert("Error de comunicación con Staging."); }
      finally { btn.disabled = false; btn.innerText = "Evaluar Canción"; }
    }

    function renderResult(data) {
      $("analysisPlaceholder").classList.add("hidden");
      $("resultsWrapper").classList.remove("hidden");
      const risk = data.risk_percent || 0;
      const hero = $("statusHero");
      hero.classList.remove('border-green-400', 'border-orange-400', 'border-red-500', 'bg-green-50/30', 'bg-orange-50/30', 'bg-red-50/30');

      if (risk < 25) {
        hero.classList.add('border-green-400', 'bg-green-50/30');
        $("suitabilityIcon").className = "p-6 rounded-3xl bg-green-100 text-green-600";
      } else if (risk < 50) {
        hero.classList.add('border-orange-400', 'bg-orange-50/30');
        $("suitabilityIcon").className = "p-6 rounded-3xl bg-orange-100 text-orange-600";
      } else {
        hero.classList.add('border-red-500', 'bg-red-50/30');
        $("suitabilityIcon").className = "p-6 rounded-3xl bg-red-100 text-red-600";
      }

      $("summaryTitle").textContent = data.resultado;
      $("summaryCopy").textContent = data.resumen;
      $("riskValue").textContent = `${risk}%`;
      $("edadSugerida").textContent = data.edad_sugerida;
      $("cursosSugeridos").textContent = (data.cursos_sugeridos || []).join(", ");
      $("lecturaSugerida").textContent = data.lectura_sugerida || "Uso Mediado";
      $("explicacionPedagogica").textContent = data.explicacion_pedagogica;
    }
    $("analyzeBtn").onclick = analizar;
  </script>
</body>
</html>
